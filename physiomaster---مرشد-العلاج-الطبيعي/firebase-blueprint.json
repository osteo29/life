{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and overall progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "startDate": { "type": "string", "format": "date", "description": "The date the user started their plan." },
        "reminderEnabled": { "type": "boolean", "description": "Whether daily reminders are enabled." },
        "reminderTime": { "type": "string", "description": "The time for the daily reminder." },
        "fcmToken": { "type": "string", "description": "Firebase Cloud Messaging token for notifications." },
        "assessmentChecklist": { "type": "object", "description": "User's progress on the assessment checklist." },
        "notes": { "type": "string", "description": "User's personal notes." },
        "darkMode": { "type": "boolean", "description": "User's theme preference." },
        "waterReminder": { "type": "boolean", "description": "Whether water reminders are enabled." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "The last time the user logged in." }
      },
      "required": ["uid", "email"]
    },
    "UserTask": {
      "title": "User Task",
      "description": "A custom task created by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique task ID." },
        "uid": { "type": "string", "description": "Owner's UID." },
        "text": { "type": "string", "description": "Task content." },
        "completed": { "type": "boolean", "description": "Completion status." },
        "date": { "type": "string", "format": "date", "description": "The date the task is scheduled for." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the task was created." }
      },
      "required": ["id", "uid", "text", "completed", "date"]
    },
    "CurriculumProgress": {
      "title": "Curriculum Progress",
      "description": "Tracks completion of specific curriculum days.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID." },
        "dayId": { "type": "string", "description": "The ID of the day (e.g., '1_1_1')." },
        "completed": { "type": "boolean", "description": "Whether the day is completed." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time." }
      },
      "required": ["uid", "dayId", "completed"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{uid}/tasks/{taskId}": {
      "schema": "UserTask",
      "description": "User's custom tasks."
    },
    "/users/{uid}/progress/{dayId}": {
      "schema": "CurriculumProgress",
      "description": "User's curriculum progress."
    }
  }
}
